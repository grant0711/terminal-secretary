#!/bin/bash

# Path to the project directory (resolving symlinks)
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" &> /dev/null && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
PROJECT_DIR="$( cd -P "$( dirname "$SOURCE" )" &> /dev/null && pwd )"

# Default command if none provided
COMMAND=${1:-record}
shift

case "$COMMAND" in
    record)
        sudo docker-compose -f "$PROJECT_DIR/docker-compose.yml" run --rm terminal-secretary python3 main.py record "$@"
        ;;
    search)
        sudo docker-compose -f "$PROJECT_DIR/docker-compose.yml" run --rm terminal-secretary python3 main.py search "$@"
        ;;
    todo)
        sudo docker-compose -f "$PROJECT_DIR/docker-compose.yml" run --rm terminal-secretary python3 main.py todo "$@"
        ;;
    review)
        sudo docker-compose -f "$PROJECT_DIR/docker-compose.yml" run --rm terminal-secretary python3 main.py review "$@"
        ;;
    build)
        sudo docker-compose -f "$PROJECT_DIR/docker-compose.yml" build
        ;;
    *)
        echo "Usage: secretary {record|search|todo|review|build} [args]"
        exit 1
        ;;
esac
