# Secretary Audio Configuration
# Run 'pactl list short sources' on your host to find these names

# Your physical microphone source
MIC_SOURCE=alsa_input.pci-0000_00_1f.3.analog-stereo

# Your system output monitor source (where colleagues' voices come from)
MONITOR_SOURCE=alsa_output.pci-0000_00_1f.3.analog-stereo.monitor

# Your Linux User ID (run 'id -u' to find it)
USER_ID=1000

# STT Model size (tiny, base, small, medium, large-v3)
MODEL_SIZE=small

# Ollama settings
OLLAMA_HOST=http://localhost:11434
SUMMARIZER_MODEL=llama3
